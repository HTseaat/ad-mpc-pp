# Copy this file to cluster.env and fill your real values.

# SSH user used by all nodes.
NODE_SSH_USERNAME="root"

# Unified docker image tag used by both admpc and dumbo-mpc docker-compose files.
# If omitted, scripts fall back to compose default (continuum:latest).
MPC_IMAGE="continuum:latest"

# Optional parent directory under remote HOME that contains admpc/ and dumbo-mpc/.
# Example for your layout: REMOTE_WORKSPACE_DIR="Continuum"
# If omitted, scripts assume repos are directly under HOME.
REMOTE_WORKSPACE_DIR="Continuum"

# Ordered list of server public IPs.
# The order defines logical node index.
CLUSTER_IPS=(
  "101.35.81.206"
  "124.221.25.126"
  "42.192.8.61"
  "111.229.49.33"
)
